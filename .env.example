# Control plane MANAtimebank (provisioning réel des espaces temps).
# Tant que ces variables sont ABSENTES, /creer reste en mode "demande qualifiée"
# (Web3Forms). Dès qu'elles sont posées (+ fonction déployée), /creer crée un
# vrai espace via l'edge function provision-space.
#
# À poser dans Vercel → Project → Settings → Environment Variables.

VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key-publique>
